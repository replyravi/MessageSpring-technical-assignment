# Local development defaults. Copy to .env and tweak.
DATABASE_URL="postgresql://ecom:ecom@localhost:5432/ecom?schema=public"

# Where the API listens.
PORT=4000

# Comma-separated list of allowed Next.js origins.
CORS_ORIGIN="http://localhost:3000"

# Cookie security. Set to "true" when serving over HTTPS in prod.
COOKIE_SECURE="false"

# Session tuning (ms). The 30-minute idle window is the security-sensitive one.
SESSION_COOKIE="sid"
SESSION_TTL_MS=28800000   # 8h absolute lifetime
SESSION_IDLE_MS=1800000   # 30 min inactivity timeout

# Login brute-force protection.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MS=300000      # 5 min lockout window

# Demo user password created by `prisma:seed`.
SEED_USER_PASSWORD=Password123!
